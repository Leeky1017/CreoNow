{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "types": [
      "node"
    ],
    "jsx": "react-jsx",
    "paths": {
      "@/*": [
        "./renderer/src/*"
      ],
      "@shared/*": [
        "../../packages/shared/*"
      ]
    }
  },
  "include": [
    "electron.vite.config.ts",
    ".storybook/**/*.ts",
    "main/src/**/*.ts",
    "preload/src/**/*.ts",
    "renderer/src/**/*.ts",
    "renderer/src/**/*.tsx",
    "shared/**/*.ts",
    "tests/**/*.ts",
    "vitest.config.core.ts",
    "renderer/src/**/*.d.ts",
    "renderer/src/**/*.test.ts",
    "renderer/src/**/*.test.tsx",
    "vitest.config.ts"
  ]
}
