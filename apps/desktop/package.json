    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.11.0",
    "@types/pdfkit": "^0.17.4",
    "@vitest/coverage-v8": "^4.0.18",
    "electron": "^40.1.0",
    "electron-builder": "^26.4.0",
    "electron-rebuild": "^3.2.9",
    "electron-vite": "^5.0.0",
    "jszip": "^3.10.1",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
