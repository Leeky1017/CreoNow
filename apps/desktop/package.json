{
  "name": "@creonow/desktop",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "dist/main/index.js",
  "scripts": {
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "rebuild:native": "electron-rebuild -f -w better-sqlite3",
    "typecheck": "tsc -p tsconfig.json --noEmit",
