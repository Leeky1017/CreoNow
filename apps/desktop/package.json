{
  "name": "@creonow/desktop",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "dist/main/index.js",
  "scripts": {
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "rebuild:native": "electron-rebuild -f -w better-sqlite3",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --config vitest.config.core.ts",
    "test:run": "vitest run --config vitest.config.core.ts",
    "test:coverage:core": "vitest run --coverage --config vitest.config.core.ts",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build -o storybook-static",
    "test:renderer": "vitest run --config vitest.config.ts"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.2.4",
    "better-sqlite3": "^12.6.2",
    "clsx": "^2.1.1",
    "docx": "^9.5.1",
    "lucide-react": "^1.7.0",
    "pdfkit": "^0.17.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sqlite-vec": "0.1.7-alpha.2",
    "tailwind-merge": "^3.5.0",
    "yaml": "^2.4.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@storybook/addon-docs": "^10.3.3",
    "@storybook/react-vite": "^10.3.3",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.11.0",
    "@types/pdfkit": "^0.17.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^4.0.18",
    "electron": "^40.1.0",
    "electron-builder": "^26.4.0",
    "electron-rebuild": "^3.2.9",
    "electron-vite": "^5.0.0",
    "jsdom": "^29.0.1",
    "jszip": "^3.10.1",
    "storybook": "^10.3.3",
    "tailwindcss": "^4.0.0",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
